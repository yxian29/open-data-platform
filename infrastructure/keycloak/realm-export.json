{
  "realm": "odp",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Full platform access"
      },
      {
        "name": "analyst",
        "description": "Read/write access to data and pipelines"
      },
      {
        "name": "viewer",
        "description": "Read-only access"
      }
    ]
  },
  "clients": [
    {
      "clientId": "odp-api",
      "name": "ODP API",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "odp-api-secret",
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": ["http://localhost:8000/*"],
      "webOrigins": ["http://localhost:8000"],
      "defaultClientScopes": ["openid", "email", "profile", "roles"],
      "protocolMappers": [
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "odp-frontend",
      "name": "ODP Frontend",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "redirectUris": ["http://localhost:3000/*"],
      "webOrigins": ["http://localhost:3000"],
      "defaultClientScopes": ["openid", "email", "profile", "roles"]
    }
  ],
  "users": [
    {
      "username": "admin",
      "email": "admin@odp.local",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Admin",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": ["admin", "analyst", "viewer"]
    },
    {
      "username": "analyst",
      "email": "analyst@odp.local",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Analyst",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "analyst",
          "temporary": false
        }
      ],
      "realmRoles": ["analyst", "viewer"]
    },
    {
      "username": "viewer",
      "email": "viewer@odp.local",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Viewer",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "viewer",
          "temporary": false
        }
      ],
      "realmRoles": ["viewer"]
    }
  ]
}
